# ====================================================
# Nabatech Backend - Complete Environment Variables
# ====================================================

# ----------------------------------------------------
# Application Environment
# ----------------------------------------------------
# Define the environment mode (development, test, production)
NODE_ENV=development
# The port the backend server listens on
PORT=10000
# Deployment configuration (single-instance, multi-instance, serverless)
DEPLOYMENT_MODE=single-instance
# URL of the frontend application (used for CORS and email links)
FRONTEND_URL=https://nabatech.app
# Comma-separated list of allowed origins for CORS
ALLOWED_ORIGINS=http://localhost:3000,https://nabatech.app

# ----------------------------------------------------
# Database Configuration
# ----------------------------------------------------
# Primary MongoDB connection string
MONGO_URI=mongodb://127.0.0.1:27017/nabatech
# Alternative MongoDB connection string (used if MONGO_URI is empty)
MONGODB_URI=mongodb://127.0.0.1:27017/nabatech
# Connection string for automated tests
MONGODB_URI_TEST=mongodb://127.0.0.1:27017/nabatech_test
# Timeout for server startup connection in milliseconds
MONGOMS_SERVER_STARTUP_TIMEOUT=60000

# ----------------------------------------------------
# Authentication & Security
# ----------------------------------------------------
# Secret key for signing JSON Web Tokens (Access Tokens)
JWT_SECRET=supersecretjwtkey12345!
# Secret key for signing Refresh Tokens
JWT_REFRESH_SECRET=real-refresh-secret-123!
# Secret key used for hashing internal tokens
TOKEN_HASH_SECRET=real-token-secret-456!
# Master key used to encrypt/decrypt AI API keys stored in the database
AI_SECRETS_ENCRYPTION_KEY=your-encryption-key-here
# Secret required to trigger internal cron job routes securely
CRON_SECRET=your-cron-secret-here

# ----------------------------------------------------
# Cloudinary (Storage)
# ----------------------------------------------------
# Cloudinary Cloud Name for image uploads
CLOUDINARY_CLOUD_NAME=dummy
# Cloudinary API Key
CLOUDINARY_API_KEY=dummy
# Cloudinary API Secret
CLOUDINARY_API_SECRET=dummy

# ----------------------------------------------------
# Email Services (SMTP)
# ----------------------------------------------------
# SMTP Server Host (e.g., smtp.gmail.com)
SMTP_HOST=smtp.gmail.com
# SMTP Server Port (e.g., 587)
SMTP_PORT=587
# SMTP Username (usually your email address)
SMTP_USER=your-email@gmail.com
# SMTP Password or App Password
SMTP_PASS=your-app-password
# Legacy/Alternative variable for Email Username
EMAIL_USER=your-email@gmail.com
# Legacy/Alternative variable for Email Password
EMAIL_PASS=your-app-password

# ----------------------------------------------------
# AI & LLM Configuration
# ----------------------------------------------------
# Default LLM Provider (e.g., openai, anthropic, gemini)
LLM_PROVIDER=openai
# OpenAI API Key for AI features
OPENAI_API_KEY=sk-your-openai-api-key
# Default model to use (e.g., gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini
# Base system prompt for the AI assistant
AI_SYSTEM_PROMPT="You are a helpful agriculture assistant."
# Timeout for LLM requests in milliseconds
AI_LLM_TIMEOUT_MS=25000
# Top K results to retrieve for chat context
AI_CHAT_TOP_K=8
# Order of fallback mechanisms for chat (e.g., rag,llm)
AI_CHAT_FALLBACK_ORDER=rag,llm
# Order of fallback mechanisms for diagnosis (e.g., cnn,llm)
AI_DIAGNOSIS_FALLBACK_ORDER=cnn
# Allow backend to fallback to LLM if CNN fails
AI_ALLOW_BACKEND_FALLBACK_TO_LLM=true

# ----------------------------------------------------
# CNN Configuration (Diagnosis)
# ----------------------------------------------------
# Provider for CNN diagnosis (e.g., huggingface-space)
CNN_PROVIDER=huggingface-space
# URL for the CNN inference endpoint
CNN_ENDPOINT_URL=https://huggingface.co/space/your/cnn
# Expected image input size for the CNN
CNN_INPUT_SIZE=224
# Whether the image requires preprocessing before sending
CNN_PREPROCESS_REQUIRED=false
# Minimum confidence threshold (0.0 to 1.0)
CNN_CONFIDENCE_THRESHOLD=0.5
# Timeout for CNN requests in milliseconds
AI_CNN_TIMEOUT_MS=35000
# Allow Flutter mobile app to run offline models
AI_ALLOW_FLUTTER_OFFLINE_MODEL=true
# AI Pipeline: allow answering if CNN fails
AI_PIPELINE_ALLOW_ANSWER_IF_CNN_FAILS=true
# AI Pipeline: allow answering after successful diagnosis
AI_PIPELINE_ANSWER_AFTER_DIAGNOSIS=true
# AI Pipeline: prioritize image processing
AI_PIPELINE_IMAGE_FIRST=true
# AI Pipeline: behavior on low confidence (warn, reject, etc.)
AI_PIPELINE_LOW_CONFIDENCE_BEHAVIOR=warn

# ----------------------------------------------------
# RAG Configuration
# ----------------------------------------------------
# URL for the Retrieval-Augmented Generation endpoint
RAG_ENDPOINT_URL=https://your-rag-endpoint.com
# Timeout for RAG requests in milliseconds
AI_RAG_TIMEOUT_MS=20000

# ----------------------------------------------------
# Dashboard & Admin Setup
# ----------------------------------------------------
# Email for the default admin user seeded into the DB
DEFAULT_ADMIN_EMAIL=admin@nabatech.com
# Password for the default admin user
DEFAULT_ADMIN_PASSWORD=Admin1234
# Name for the default admin user
DEFAULT_ADMIN_NAME="Nabatech Admin"
# Email for the super admin role
SUPER_ADMIN_EMAIL=superadmin@nabatech.local
# Password for the super admin role
SUPER_ADMIN_PASSWORD=SuperSecret123!
