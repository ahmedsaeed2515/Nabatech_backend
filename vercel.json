{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": ".",
  "builds": [
    {
      "src": "dist/vercel.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/dist/vercel.js"
    }
  ],
  "crons": [
    {
      "path": "/api/internal/warmup-ai",
      "schedule": "*/4 * * * *"
    }
  ]
}
